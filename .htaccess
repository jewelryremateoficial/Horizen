# ============================================================
# FinancialOS — Horizen.com.mx
# App SaaS 100% independiente — sin WordPress
# ============================================================

DirectoryIndex index.html

Options -MultiViews
RewriteEngine On
RewriteBase /

# ── Archivos y carpetas reales (incluyendo .html) pasan directo
# IMPORTANTE: este bloque va PRIMERO para que dashboard.html
# no sea capturado por las reglas de abajo y se sirva directo,
# preservando el ?code= de Supabase OAuth (PKCE).
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ── URLs limpias → sirve el .html SIN redirigir (sin 301) ───
# Permite /dashboard Y /dashboard.html — ambas funcionan.
RewriteRule ^login/?$              login.html              [L]
RewriteRule ^signup/?$             signup.html             [L]
RewriteRule ^pricing/?$            pricing.html            [L]
RewriteRule ^dashboard/?$          dashboard.html          [L]
RewriteRule ^reset-password/?$     reset-password.html     [L]
RewriteRule ^admin/dashboard/?$    admin/dashboard.html    [L]

# ── Genérico: cualquier ruta sin extensión → busca el .html ──
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Seguridad
Options -Indexes
