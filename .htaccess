# ============================================================
# FinancialOS — Horizen.com.mx
# App SaaS 100% independiente — sin WordPress
# ============================================================

DirectoryIndex index.html

Options -MultiViews
RewriteEngine On
RewriteBase /

# ── Redirigir .html → URL limpia ────────────────────────────
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# ── Rutas de la app ──────────────────────────────────────────
RewriteRule ^login/?$              login.html              [L]
RewriteRule ^signup/?$             signup.html             [L]
RewriteRule ^pricing/?$            pricing.html            [L]
RewriteRule ^dashboard/?$          dashboard.html          [L]
RewriteRule ^reset-password/?$     reset-password.html     [L]
RewriteRule ^admin/dashboard/?$    admin/dashboard.html    [L]

# ── Archivos y carpetas reales pasan directo ─────────────────
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ── Genérico: .html sin extensión ───────────────────────────
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# Seguridad
Options -Indexes
